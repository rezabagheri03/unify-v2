# ════════════════════════════════════════════════════════════════════════
# Unify Platform — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to source control
# ════════════════════════════════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────────────────────────────────
# Connection pool sized for 10k concurrent users (Agent Guide §F.6).
# 50 connections per app instance × 4 instances (PM2 cluster) = 200 connections.
DATABASE_URL="postgresql://unify_user:unify_password@localhost:5432/unify_db?connection_limit=50&pool_timeout=20"
# For Docker: postgresql://unify_user:unify_password@postgres:5432/unify_db?connection_limit=50&pool_timeout=20

# ── REDIS ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# For Docker: redis://redis:6379

# ── JWT ────────────────────────────────────────────────────────────────────
# CRITICAL: These MUST be at least 64 characters each.
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET="CHANGE_THIS_TO_64_CHAR_RANDOM_STRING_MINIMUM_LENGTH_REQUIRED_FOR_SECURITY"
JWT_REFRESH_SECRET="CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_STRING_DIFFERENT_FROM_ACCESS_SECRET"
JWT_ACCESS_EXPIRY="1h"
JWT_REFRESH_EXPIRY="7d"

# ── BCRYPT ─────────────────────────────────────────────────────────────────
BCRYPT_COST_FACTOR=12

# ── FILE STORAGE ───────────────────────────────────────────────────────────
STORAGE_BASE_PATH="./storage"
MAX_FILE_SIZE_BYTES=52428800
MAX_TICKET_IMAGE_SIZE_BYTES=5242880
STUDENT_DAILY_UPLOAD_QUOTA=5
MAX_TICKET_IMAGES=3

# ── PUSHE (Iranian National Intranet Push Notification Service) ────────────
PUSHE_APP_ID="your_pushe_app_id"
PUSHE_API_KEY="your_pushe_api_key"
PUSHE_API_URL="https://api.pushe.co/v2"
# If Pushe credentials are missing, system falls back to Socket.io (in-app only)

# ── SERVER ─────────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
API_BASE_URL="http://localhost:3001"

# Skip BullMQ workers in this process — set "true" when running jobs separately.
# See ecosystem.config.js → unify-jobs process.
SKIP_JOB_WORKERS="false"

# ── SYSTEM OWNER SEED (used by prisma/seed.ts) ─────────────────────────────
SEED_OWNER_USERNAME="owner"
SEED_OWNER_PASSWORD="ChangeThisOnFirstLogin!1"

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── RATE LIMITING ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_MESSAGE_MAX=30

# ── TIMEZONE ───────────────────────────────────────────────────────────────
TZ="Asia/Tehran"

# ── LOGGING ────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
